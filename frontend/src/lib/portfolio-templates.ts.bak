// ─── Helper Functions ─────────────────────────────────────────────

export const getGoogleFontsUrl = (fonts: FontPairing): string => {
  const families = [fonts.heading, fonts.body, fonts.mono]
    .map((f) => f.replace(/'/g, "").replace(/\s+/g, "+"))
    .filter((v, i, a) => a.indexOf(v) === i);
  return `https://fonts.googleapis.com/css2?family=${families.join("&family=")}&display=swap`;
};

export const TemplateRegistry = {
  getAll: () => TEMPLATES,
  getById: (id: string) => TEMPLATES.find((t) => t.id === id) || TEMPLATES[0],
  getByCategory: (cat: string) =>
    cat === "all" ? TEMPLATES : TEMPLATES.filter((t) => t.recommendedFor.includes(cat as any)),
};

export const getDefaultCustomization = (templateId: string): CustomizationOptions => {
  const t = TemplateRegistry.getById(templateId);
  return {
    colors: { ...t.defaultColors },
    fonts: { ...t.defaultFonts },
    animation: { ...t.animationProfile },
    visualStyle: { ...t.visualStyle },
    layout: t.layout,
    imageShape: "circle",
    imageSize: "medium",
    showSectionNumbers: false,
    sectionInstances: t.sections.map((s) => ({ ...s })),
    sectionVariants: {},
    elementStyles: {},
  };
};