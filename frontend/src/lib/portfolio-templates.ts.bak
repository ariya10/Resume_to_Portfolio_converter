// ─── Core Interfaces ───────────────────────────────────────────────

export interface PortfolioData {
  name: string;
  title: string;
  email: string;
  phone: string;
  location: string;
  linkedin: string;
  github: string;
  website: string;
  summary: string;
  bio: string;
  skills: string[];
  skillCategories: Record<string, string[]>;
  experience: {
    company: string;
    role: string;
    duration: string;
    description: string;
    highlights: string[];
  }[];
  education: {
    institution: string;
    degree: string;
    duration: string;
    gpa: string;
    highlights: string[];
  }[];
  projects: {
    name: string;
    description: string;
    technologies: string[];
    link: string;
  }[];
  certifications: string[];
  languages: string[];
  interests: string[];
  userType: string;
  portfolioTone: string;
  profileImage: string | null;
}

export type UserType = "student" | "fresher" | "professional" | "freelancer" | "developer";
export type LayoutType = "single-column" | "sidebar-left" | "sidebar-right" | "split-hero" | "bento-grid" | "magazine" | "timeline-center" | "card-stack" | "fullscreen-sections" | "asymmetric" | "minimal-center";
export type ScrollAnimation = "fade-up" | "fade-in" | "slide-left" | "slide-right" | "scale-up" | "flip" | "parallax" | "blur-in" | "typewriter";
export type HoverEffect = "lift" | "scale" | "glow" | "border-glow" | "tilt";
export type ImageShape = "circle" | "rounded" | "square";
export type ImageSize = "small" | "medium" | "large";
export type ViewportSize = "desktop" | "tablet" | "mobile";

export interface ColorPalette {
  primary: string;
  secondary: string;
  accent: string;
  background: string;
  surface: string;
  text: string;
  textSecondary: string;
}

export interface FontPairing {
  heading: string;
  headingWeight: string;
  body: string;
  bodyWeight: string;
  mono: string;
}

export interface AnimationProfile {
  scrollType: ScrollAnimation;
  scrollThreshold: number;
  hoverEffects: HoverEffect[];
  staggerReveal: boolean;
  staggerDelay: number;
  staggerIncrement: number;
  reducedMotion: boolean;
}

export interface VisualStyleConfig {
  glassmorphism: boolean;
  glassBlur: number;
  glassOpacity: number;
  shadowLevel: "none" | "sm" | "md" | "lg" | "xl" | "glow";
  auroraBackground: boolean;
  auroraColors: string[];
  meshGradient: boolean;
  meshColors: string[];
  spotlightEffect: boolean;
  spotlightColor: string;
  patternOverlay: "none" | "dots" | "grid" | "diagonal" | "circles" | "waves";
  gradientAngle: number;
}

export interface SectionInstance {
  id: string;
  type: string;
  label: string;
  visible: boolean;
}

export interface CustomizationOptions {
  colors: ColorPalette;
  fonts: FontPairing;
  animation: AnimationProfile;
  visualStyle: VisualStyleConfig;
  layout: LayoutType;
  imageShape: ImageShape;
  imageSize: ImageSize;
  showSectionNumbers: boolean;
  profileImage?: string | null;
  sectionVariants?: Record<string, string>;
  sectionInstances: SectionInstance[];
  elementStyles?: Record<string, Record<string, string>>;
}

export const DEFAULT_SECTIONS: SectionInstance[] = [
  { id: "hero", type: "hero", label: "Hero", visible: true },
  { id: "about", type: "about", label: "About", visible: true },
  { id: "skills", type: "skills", label: "Skills", visible: true },
  { id: "experience", type: "experience", label: "Experience", visible: true },
  { id: "projects", type: "projects", label: "Projects", visible: true },
  { id: "contact", type: "contact", label: "Contact", visible: true },
];

export interface TemplateConfig {
  id: string;
  name: string;
  description: string;
  preview: string;
  tags: string[];
  recommendedFor: UserType[];
  layout: LayoutType;
  defaultColors: ColorPalette;
  defaultFonts: FontPairing;
  animationProfile: AnimationProfile;
  visualStyle: VisualStyleConfig;
  supportsImage: boolean;
  sections: SectionInstance[];
}

